# Database
DATABASE_URL="postgresql://user:password@localhost:5432/smart_parking"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET="your-super-secret-key-change-this"
JWT_EXPIRE="7d"

# Stripe
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLIC_KEY="pk_test_xxx"

# Redis
REDIS_URL="redis://localhost:6379"

# Firebase
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_PRIVATE_KEY="your-private-key"
FIREBASE_CLIENT_EMAIL="your-email"

# Twilio (для SMS OTP)
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# SendGrid (для email)
SENDGRID_API_KEY="your-sendgrid-key"
SENDGRID_FROM_EMAIL="noreply@smartparking.kz"

# LPR
LPR_WEBHOOK_SECRET="your-lpr-webhook-secret"

# Parking Config
SHORT_TERM_MIN_FEE=150
SHORT_TERM_RATE_PER_MIN=3
EXTEND_BOOKING_COST=75
EXTEND_BOOKING_DURATION=1800
FREE_BOOKING_DURATION=900

# Ban System
BAN_THRESHOLD=6
BAN_DURATION=259200
