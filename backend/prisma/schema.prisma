// This is your Prisma schema file,
// learn more about it in docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String      @id @default(cuid())
  phoneNumber           String      @unique
  firstName             String?
  lastName              String?
  email                 String?     @unique
  carPlate              String?     @unique
  walletBalance         Float       @default(0)
  noShowCount           Int         @default(0)
  isBanned              Boolean     @default(false)
  bannedUntil           DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  // Relations
  bookings              Booking[]
  transactions          Transaction[]
  payments              Payment[]
  renewalNotifications  RenewalNotification[]
  longTermRentals       LongTermRental[]

  @@map("users")
}

model ParkingSpot {
  id                    String      @id @default(cuid())
  spotNumber            String      @unique
  type                  SpotType    @default(SHORT_TERM)
  status                SpotStatus  @default(FREE)
  currentUserPlate      String?
  currentUserId         String?     @db.Uuid
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  // Relations
  bookings              Booking[]
  longTermRentals       LongTermRental[]

  @@map("parking_spots")
}

model Booking {
  id                    String      @id @default(cuid())
  userId                String
  spotId                String
  startTime             DateTime
  estimatedEndTime      DateTime
  actualEndTime         DateTime?
  status                BookingStatus @default(PENDING)
  isPaid                Boolean     @default(false)
  totalCost             Float       @default(0)
  minutesExtended       Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  // Relations
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot                  ParkingSpot @relation(fields: [spotId], references: [id], onDelete: Cascade)
  payment               Payment?

  @@map("bookings")
}

model LongTermRental {
  id                    String      @id @default(cuid())
  userId                String
  spotId                String
  rentalDays            Int         // 1, 3, 5, 7, 14
  totalCost             Float
  startDate             DateTime
  endDate               DateTime
  isPaid                Boolean     @default(false)
  status                RentalStatus @default(ACTIVE)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  // Relations
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot                  ParkingSpot @relation(fields: [spotId], references: [id], onDelete: Cascade)
  payment               Payment?
  renewalNotification   RenewalNotification?

  @@map("long_term_rentals")
}

model Payment {
  id                    String      @id @default(cuid())
  userId                String
  bookingId             String?    @unique
  rentalId              String?    @unique
  amount                Float
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  paymentMethod         PaymentMethod @default(WALLET)
  transactionId         String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  
  // Relations
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking               Booking?    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rental                LongTermRental? @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Transaction {
  id                    String      @id @default(cuid())
  userId                String
  amount                Float
  type                  TransactionType
  description           String?
  balanceBefore         Float
  balanceAfter          Float
  createdAt             DateTime    @default(now())
  
  // Relations
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model RenewalNotification {
  id                    String      @id @default(cuid())
  userId                String
  rentalId              String
  notificationTime      DateTime
  isSent                Boolean     @default(false)
  createdAt             DateTime    @default(now())
  
  // Relations
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  rental                LongTermRental @relation(fields: [rentalId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([rentalId])
  @@map("renewal_notifications")
}

model PromoCode {
  id                    String      @id @default(cuid())
  code                  String      @unique
  discount              Float       // в тенге
  type                  PromoType
  maxUses               Int?
  usedCount             Int         @default(0)
  isActive              Boolean     @default(true)
  expiresAt             DateTime?
  createdAt             DateTime    @default(now())

  @@map("promo_codes")
}

model LPREvent {
  id                    String      @id @default(cuid())
  carPlate              String
  eventType             LPREventType
  timestamp             DateTime    @default(now())
  spotNumber            String?
  imageUrl              String?
  confidence            Float?
  
  @@map("lpr_events")
}

// Enums
enum SpotType {
  SHORT_TERM
  LONG_TERM
}

enum SpotStatus {
  FREE
  BOOKED
  OCCUPIED
  RESERVED
  REPAIR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum RentalStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  WALLET
  STRIPE
  CARD
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  REFUND
  CASHBACK
  PROMO
}

enum PromoType {
  PERCENTAGE
  FIXED
  FIRST_RIDE
}

enum LPREventType {
  ENTRY
  EXIT
}
