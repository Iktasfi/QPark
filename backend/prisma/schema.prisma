// This is your Prisma schema file,
// learn more about it in docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String      @id @default(cuid())
  phone           String      @unique
  name            String?
  balance         Float       @default(0)
  inAllowCount    Int         @default(0) // in_allow_count
  isBanned        Boolean     @default(false) // is_banned
  banUntil        DateTime?   // ban_until
  createdAt       DateTime    @default(now()) // created_at
  updatedAt       DateTime    @updatedAt // updated_at
  
  // Relations
  bookings        Booking[]
  vehicles        Vehicle[]
  walletTransactions WalletTransaction[]

  @@map("users")
}

model Vehicle {
  id        String  @id @default(cuid())
  userId    String  // user_id
  plate     String  // plate
  brand     String? // brand
  model     String? // model
  isDefault Boolean @default(false) // is_default
  createdAt DateTime @default(now())
  
  // Relations
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings  Booking[]

  @@unique([userId, plate])
  @@map("vehicles")
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  promoType     PromoType // promo_type
  discountValue Float     // discount_value
  minSum        Float?    // min_sum
  usedCount     Int       @default(0) // used_count
  maxCount      Int?      // max_count
  expiresAt     DateTime? // expires_at
  createdAt     DateTime  @default(now())
  
  // Relations
  bookings      Booking[]

  @@map("promo_codes")
}

model Booking {
  id              String        @id @default(cuid())
  userId          String        // user_id
  vehicleId       String        // vehicle_id
  promoCodeId     String?       // promo_code_id
  type            BookingType   // type
  bookingStatus   BookingStatus // booking_status
  plate           String        // plate
  amount          Float         // amount
  isPaid         Boolean       @default(false) // is_paid
  arrivedAt       DateTime?     // arrived_at
  collectedAt     DateTime?     // collected_at
  completedAt     DateTime?     // completed_at
  createdAt       DateTime      @default(now()) // created_at
  
  // Relations
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicle         Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  promoCode       PromoCode?    @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)
  longTermDetails LongTermDetails?
  shortTermDetails ShortTermDetails?
  walletTransactions WalletTransaction[]

  @@map("bookings")
}

model LongTermDetails {
  id        String   @id @default(cuid())
  bookingId String   @unique // booking_id
  duration  Int      // duration in days
  startsAt  DateTime // starts_at
  endsAt    DateTime // ends_at
  amount    Float    // amount
  
  // Relations
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("long_term_details")
}

model ShortTermDetails {
  id                       String    @id @default(cuid())
  bookingId                String    @unique // booking_id
  arrivedAt                DateTime? // arrived_at
  collectedAt              DateTime? // collected_at
  waitingFreePaidMinutes   Int?      // waiting_free_paid_minutes
  minDueMinutes            Int?      // min_due_minutes
  
  // Relations
  booking                  Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("short_term_details")
}

model WalletTransaction {
  id                    String              @id @default(cuid())
  userId                String              // user_id
  bookingId             String?             // booking_id
  type                  TransactionType     // type
  amount                Float               // amount
  balanceAfter          Float               // balance_after
  description           String?             // description
  stripePaymentIntentId String?             // stripe_payment_intent_id
  createdAt             DateTime            @default(now()) // created_at
  
  // Relations
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking               Booking?            @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("wallet_transactions")
}

model ParkingPoint {
  id            String      @id @default(cuid())
  name          String      // name
  code          String      @unique // code
  type          String      // type
  status        String      @default("active") // status
  currentPlace  String?     // current_place
  updatedAt     DateTime    @updatedAt // updated_at
  
  @@map("parking_points")
}

// Enums
enum PromoType {
  PERCENTAGE
  FIXED
  FIRST_RIDE
}

enum BookingType {
  SHORT_TERM
  LONG_TERM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  REFUND
  CASHBACK
  PROMO
}
