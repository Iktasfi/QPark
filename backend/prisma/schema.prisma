generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ───────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  phoneNumber   String    @unique
  firstName     String?
  lastName      String?
  walletBalance Float     @default(0)
  bonusPoints   Int       @default(0)
  noShowCount   Int       @default(0)
  isBanned      Boolean   @default(false)
  bannedUntil   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cars                 Car[]
  bookings             Booking[]
  longTermRentals      LongTermRental[]
  transactions         Transaction[]
  payments             Payment[]
  renewalNotifications RenewalNotification[]
  complaints           Complaint[]

  @@map("users")
}

// ─── CARS ────────────────────────────────────────────────
model Car {
  id          String    @id @default(cuid())
  userId      String
  brand       String
  model       String
  plateNumber String    @unique
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cars")
}

// ─── PARKING SPOTS ───────────────────────────────────────
model ParkingSpot {
  id               String     @id @default(cuid())
  spotNumber       String     @unique
  type             SpotType   @default(SHORT_TERM)
  status           SpotStatus @default(FREE)
  currentUserPlate String?
  currentUserId    String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  bookings        Booking[]
  longTermRentals LongTermRental[]

  @@map("parking_spots")
}

// ─── BOOKINGS (краткосрочные) ─────────────────────────────
model Booking {
  id               String        @id @default(cuid())
  userId           String
  spotId           String
  plateNumber      String
  startTime        DateTime
  estimatedEndTime DateTime
  actualEndTime    DateTime?
  arrivedAt        DateTime?
  status           BookingStatus @default(PENDING)
  isPaid           Boolean       @default(false)
  totalCost        Float         @default(0)
  minutesExtended  Int           @default(0)
  photoUrl         String?
  photoUploadedAt  DateTime?
  photoStatus      PhotoStatus?
  photoTimerStart  DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot    ParkingSpot @relation(fields: [spotId], references: [id], onDelete: Cascade)
  payment Payment?

  @@map("bookings")
}

// ─── LONG TERM RENTALS ────────────────────────────────────
model LongTermRental {
  id              String       @id @default(cuid())
  userId          String
  spotId          String
  plateNumber     String
  rentalDays      Int
  totalCost       Float
  startDate       DateTime
  endDate         DateTime
  arrivedAt       DateTime?
  isPaid          Boolean      @default(false)
  status          RentalStatus @default(ACTIVE)
  photoUrl        String?
  photoUploadedAt DateTime?
  photoStatus     PhotoStatus?
  photoTimerStart DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  spot                ParkingSpot          @relation(fields: [spotId], references: [id], onDelete: Cascade)
  payment             Payment?
  renewalNotification RenewalNotification?

  @@map("long_term_rentals")
}

// ─── PAYMENTS ────────────────────────────────────────────
model Payment {
  id            String        @id @default(cuid())
  userId        String
  bookingId     String?       @unique
  rentalId      String?       @unique
  amount        Float
  status        PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod @default(WALLET)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking?        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  rental  LongTermRental? @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("payments")
}

// ─── TRANSACTIONS (история кошелька) ─────────────────────
model Transaction {
  id                    String          @id @default(cuid())
  userId                String
  amount                Float
  type                  TransactionType
  description           String?
  balanceBefore         Float
  balanceAfter          Float
  stripePaymentIntentId String?
  createdAt             DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

// ─── LPR EVENTS ──────────────────────────────────────────
model LPREvent {
  id         String       @id @default(cuid())
  carPlate   String
  eventType  LPREventType
  spotNumber String?
  confidence Float?
  timestamp  DateTime     @default(now())

  @@map("lpr_events")
}

// ─── RENEWAL NOTIFICATIONS ───────────────────────────────
model RenewalNotification {
  id               String   @id @default(cuid())
  userId           String
  rentalId         String   @unique
  notificationTime DateTime
  isSent           Boolean  @default(false)
  createdAt        DateTime @default(now())

  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  rental LongTermRental @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@map("renewal_notifications")
}

// ─── ENUMS ───────────────────────────────────────────────
enum SpotType {
  SHORT_TERM
  LONG_TERM
}

enum SpotStatus {
  FREE
  BOOKED
  OCCUPIED
  RESERVED
  REPAIR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum RentalStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  WALLET
  STRIPE
}

enum TransactionType {
  DEPOSIT
  PAYMENT
  REFUND
  CASHBACK
  PROMO
}

enum LPREventType {
  ENTRY
  EXIT
}

enum PhotoStatus {
  PENDING
  UPLOADED
  CONFIRMED
  WRONG_SPOT
}

// ─── COMPLAINTS ──────────────────────────────────────────
model Complaint {
  id              String          @id @default(cuid())
  userId          String
  bookingId       String?
  spotId          String
  reason          String
  photoUrl        String?
  status          ComplaintStatus @default(PENDING)
  newSpotId       String?
  detectedPlate   String?
  violatorUserId  String?
  createdAt       DateTime        @default(now())
  resolvedAt      DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("complaints")
}

enum ComplaintStatus {
  PENDING
  REASSIGNED
  REFUNDED
  RESOLVED
}

// ─── LANDLORD APPLICATIONS ───────────────────────────────
model Application {
  id          String            @id @default(cuid())
  companyName String
  ownerName   String
  phone       String
  email       String?
  address     String
  city        String
  spotsCount  Int
  description String?
  status      ApplicationStatus @default(NEW)
  adminNote   String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("applications")
}

enum ApplicationStatus {
  NEW
  IN_REVIEW
  APPROVED
  REJECTED
}

// ─── PROMO CODES ─────────────────────────────────────────
model PromoCode {
  id         String        @id @default(cuid())
  code       String        @unique
  discount   Float
  type       PromoCodeType
  maxUses    Int?
  usedCount  Int           @default(0)
  isActive   Boolean       @default(true)
  expiresAt  DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@map("promo_codes")
}

enum PromoCodeType {
  PERCENTAGE
  FIXED
  FIRST_RIDE
}
