          <mxGeometry x="590" y="60" width="100" height="750" as="geometry"/>
        </mxCell>
        
        <mxCell id="ll-ws" value="WebSocket" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
