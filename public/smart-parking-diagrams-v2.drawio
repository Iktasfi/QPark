      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="stripe-title" value="Sequence Diagram: Stripe Wallet Top-up Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="500" height="30" as="geometry"/>
        </mxCell>
        
        <!-- Lifelines -->
        <mxCell id="stripe-ll-app" value="Mobile App" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="100" height="550" as="geometry"/>
        </mxCell>
        
        <mxCell id="stripe-ll-api" value="Backend API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="280" y="60" width="100" height="550" as="geometry"/>
        </mxCell>
        
        <mxCell id="stripe-ll-stripe" value="Stripe API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="100" height="550" as="geometry"/>
        </mxCell>
        
        <mxCell id="stripe-ll-webhook" value="Webhook&#xa;Endpoint" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="680" y="60" width="100" height="550" as="geometry"/>
        </mxCell>
        
        <mxCell id="stripe-ll-db" value="PostgreSQL" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="880" y="60" width="100" height="550" as="geometry"/>
        </mxCell>
        
        <!-- Messages -->
        <mxCell id="stripe-msg1" value="1. POST /api/wallet/topup {amount: 5000}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="130" as="sourcePoint"/>
            <mxPoint x="330" y="130" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg2" value="2. Create PaymentIntent {amount, currency: KZT}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="170" as="sourcePoint"/>
            <mxPoint x="530" y="170" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg3" value="3. {client_secret, payment_intent_id}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="530" y="210" as="sourcePoint"/>
            <mxPoint x="330" y="210" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg4" value="4. INSERT transaction (PENDING)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="250" as="sourcePoint"/>
            <mxPoint x="930" y="250" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg5" value="5. {client_secret}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="290" as="sourcePoint"/>
            <mxPoint x="130" y="290" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg6" value="6. Open Stripe Payment Sheet" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="330" as="sourcePoint"/>
            <mxPoint x="530" y="330" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-note1" value="User enters card details&#xa;in Stripe secure UI" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#fff2cc;strokeColor=#d6b656;size=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="310" width="100" height="50" as="geometry"/>
        </mxCell>
        
        <mxCell id="stripe-msg7" value="7. Confirm Payment" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="380" as="sourcePoint"/>
            <mxPoint x="530" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg8" value="8. Payment Successful" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="530" y="410" as="sourcePoint"/>
            <mxPoint x="130" y="410" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <!-- Async Webhook -->
        <mxCell id="stripe-async" value="" style="shape=umlFrame;whiteSpace=wrap;html=1;width=50;height=20;boundedLbl=1;verticalAlign=top;align=left;spacingLeft=5;fillColor=#ffe6cc;strokeColor=#d79b00;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="450" y="440" width="500" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="stripe-async-label" value="async" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="455" y="440" width="40" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="stripe-msg9" value="9. POST /webhook (payment_intent.succeeded)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeColor=#d79b00;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="530" y="480" as="sourcePoint"/>
            <mxPoint x="730" y="480" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg10" value="10. Verify webhook signature" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="510" as="sourcePoint"/>
            <mxPoint x="730" y="510" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="780" y="510"/>
              <mxPoint x="780" y="530"/>
              <mxPoint x="730" y="530"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg11" value="11. UPDATE user SET wallet_balance += amount" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="550" as="sourcePoint"/>
            <mxPoint x="930" y="550" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="stripe-msg12" value="12. UPDATE transaction SET status = SUCCESS" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="730" y="580" as="sourcePoint"/>
            <mxPoint x="930" y="580" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  
  <diagram id="state" name="8. State Diagram - Parking Spot">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="state-title" value="State Diagram: Parking Spot Lifecycle" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="30" as="geometry"/>
        </mxCell>
        
        <!-- Initial state -->
        <mxCell id="state-init" value="" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;fillColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="520" y="70" width="30" height="30" as="geometry"/>
        </mxCell>
        
        <!-- States -->
        <mxCell id="state-free" value="FREE&#xa;(Свободно)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="460" y="140" width="150" height="60" as="geometry"/>
        </mxCell>
        
        <mxCell id="state-booked" value="BOOKED&#xa;(Забронировано)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="280" width="150" height="60" as="geometry"/>
        </mxCell>
        
        <mxCell id="state-occupied" value="OCCUPIED&#xa;(Занято)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="450" width="150" height="60" as="geometry"/>
        </mxCell>
        
        <mxCell id="state-reserved" value="RESERVED&#xa;(Зарезервировано)&#xa;Long-term" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="720" y="280" width="150" height="70" as="geometry"/>
        </mxCell>
        
        <mxCell id="state-repair" value="REPAIR&#xa;(На ремонте)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="720" y="450" width="150" height="60" as="geometry"/>
        </mxCell>
        
        <!-- Transitions -->
        <mxCell id="trans-init" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="state-init" target="state-free">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="trans1" value="Бронирование&#xa;(short-term)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="state-free" target="state-booked">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="400" y="170"/>
              <mxPoint x="400" y="310"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="trans2" value="LPR: Въезд&#xa;(arrived)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="state-booked" target="state-occupied">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <mxCell id="trans3" value="LPR: Выезд&#xa;(completed)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="state-occupied" target="state-free">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="100" y="480"/>
              <mxPoint x="100" y="170"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="trans4" value="Timer 15min&#xa;(no_show)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#b85450;" edge="1" parent="1" source="state-booked" target="state-free">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="275" y="220"/>
              <mxPoint x="535" y="220"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="trans5" value="Бронирование&#xa;(long-term)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="state-free" target="state-reserved">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="670" y="170"/>
              <mxPoint x="670" y="315"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="trans6" value="LPR: Въезд" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="state-reserved" target="state-occupied">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="795" y="400"/>
              <mxPoint x="275" y="400"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="trans7" value="Reservation expired&#xa;(long-term end)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#9673a6;" edge="1" parent="1" source="state-reserved" target="state-free">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="900" y="315"/>
              <mxPoint x="900" y="100"/>
              <mxPoint x="610" y="100"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="trans8" value="Admin: Set repair" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#666666;" edge="1" parent="1" source="state-free" target="state-repair">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="200"/>
              <mxPoint x="950" y="200"/>
              <mxPoint x="950" y="480"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="trans9" value="Admin: Fixed" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#82b366;" edge="1" parent="1" source="state-repair" target="state-free">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="795" y="550"/>
              <mxPoint x="535" y="550"/>
              <mxPoint x="535" y="200"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="state-legend" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="140" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="state-leg-title" value="Легенда статусов:" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="50" y="85" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="state-leg1" value="FREE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="110" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="state-leg2" value="BOOKED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="105" y="110" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="state-leg3" value="OCCUPIED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="135" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="state-leg4" value="RESERVED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="160" width="60" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="state-leg5" value="REPAIR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="115" y="160" width="50" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="state-leg6" value="Long-term" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="115" y="135" width="50" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
