          <mxGeometry x="260" y="200" width="150" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="msg-ban" value="403 Account Banned" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;strokeColor=#b85450;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="260" as="sourcePoint"/>
            <mxPoint x="130" y="260" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <!-- Alt block for balance check -->
        <mxCell id="alt-balance" value="" style="shape=umlFrame;whiteSpace=wrap;html=1;width=40;height=20;boundedLbl=1;verticalAlign=top;align=left;spacingLeft=5;fillColor=#fff2cc;strokeColor=#d6b656;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="220" y="320" width="200" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="alt-balance-label" value="alt" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="225" y="320" width="30" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="alt-balance-cond" value="[wallet_balance = 0 AND rental_type = LONG_TERM]" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=2;fontSize=9" vertex="1" parent="1">
          <mxGeometry x="260" y="320" width="160" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="msg-balance" value="402 Insufficient Balance" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;strokeColor=#d6b656;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="380" as="sourcePoint"/>
            <mxPoint x="130" y="380" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <!-- Success path -->
        <mxCell id="msg4" value="4. Check spot availability" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="450" as="sourcePoint"/>
            <mxPoint x="640" y="450" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg5" value="5. spot status" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="640" y="480" as="sourcePoint"/>
            <mxPoint x="300" y="480" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg6" value="6. INSERT booking" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="510" as="sourcePoint"/>
            <mxPoint x="470" y="510" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg7" value="7. booking_id" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="470" y="540" as="sourcePoint"/>
            <mxPoint x="300" y="540" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg8" value="8. UPDATE spot status = BOOKED" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="570" as="sourcePoint"/>
            <mxPoint x="640" y="570" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg9" value="9. SET timer:booking:{id} 900" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="600" as="sourcePoint"/>
            <mxPoint x="640" y="600" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg10" value="10. PUBLISH spot_update" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="630" as="sourcePoint"/>
            <mxPoint x="810" y="630" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg11" value="11. broadcast to all clients" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeColor=#9673a6;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="810" y="660" as="sourcePoint"/>
            <mxPoint x="130" y="660" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg12" value="12. Send push notification" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="690" as="sourcePoint"/>
            <mxPoint x="980" y="690" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="msg13" value="13. 201 Created {booking}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="300" y="720" as="sourcePoint"/>
            <mxPoint x="130" y="720" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  
  <diagram id="sequence-lpr" name="3. Sequence - LPR Entry/Exit">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="lpr-title" value="Sequence Diagram: LPR Entry/Exit Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="30" as="geometry"/>
        </mxCell>
        
        <!-- Lifelines -->
        <mxCell id="lpr-ll-cam" value="LPR Camera&#xa;(Python)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="80" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        
        <mxCell id="lpr-ll-api" value="Backend API" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="280" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        
        <mxCell id="lpr-ll-db" value="PostgreSQL" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="480" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        
        <mxCell id="lpr-ll-redis" value="Redis" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="680" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        
        <mxCell id="lpr-ll-barrier" value="Barrier&#xa;GPIO/Relay" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="880" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        
        <!-- Entry Flow -->
        <mxCell id="lpr-note1" value="=== ENTRY FLOW ===" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="110" width="140" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="lpr-msg1" value="1. POST /api/lpr/entry {plate: &quot;ABC123&quot;}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="150" as="sourcePoint"/>
            <mxPoint x="330" y="150" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg2" value="2. Find active booking by plate" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="180" as="sourcePoint"/>
            <mxPoint x="530" y="180" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg3" value="3. booking data" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="530" y="210" as="sourcePoint"/>
            <mxPoint x="330" y="210" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg4" value="4. UPDATE booking SET arrived_at = NOW()" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="240" as="sourcePoint"/>
            <mxPoint x="530" y="240" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg5" value="5. UPDATE spot SET status = OCCUPIED" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="270" as="sourcePoint"/>
            <mxPoint x="730" y="270" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg6" value="6. DEL timer:booking:{id}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="300" as="sourcePoint"/>
            <mxPoint x="730" y="300" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg7" value="7. {success: true, action: OPEN_BARRIER}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="330" as="sourcePoint"/>
            <mxPoint x="130" y="330" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg8" value="8. GPIO.output(BARRIER_PIN, HIGH)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeColor=#d79b00;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="360" as="sourcePoint"/>
            <mxPoint x="930" y="360" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg9" value="9. Barrier opens (5 sec)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;strokeColor=#d79b00;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="930" y="390" as="sourcePoint"/>
            <mxPoint x="130" y="390" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <!-- Exit Flow -->
        <mxCell id="lpr-note2" value="=== EXIT FLOW ===" style="text;html=1;strokeColor=none;fillColor=#f8cecc;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="430" width="140" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="lpr-msg10" value="10. POST /api/lpr/exit {plate: &quot;ABC123&quot;}" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="470" as="sourcePoint"/>
            <mxPoint x="330" y="470" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg11" value="11. Find booking, check payment status" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="500" as="sourcePoint"/>
            <mxPoint x="530" y="500" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <!-- Alt for payment -->
        <mxCell id="lpr-alt" value="" style="shape=umlFrame;whiteSpace=wrap;html=1;width=40;height=20;boundedLbl=1;verticalAlign=top;align=left;spacingLeft=5;fillColor=#d5e8d4;strokeColor=#82b366;opacity=30;" vertex="1" parent="1">
          <mxGeometry x="250" y="530" width="200" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="lpr-alt-label" value="alt" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="255" y="530" width="30" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="lpr-alt-cond" value="[payment_status = PAID]" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="290" y="530" width="150" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="lpr-msg12" value="12. UPDATE booking SET completed_at" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="620" as="sourcePoint"/>
            <mxPoint x="530" y="620" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg13" value="13. UPDATE spot SET status = FREE" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="650" as="sourcePoint"/>
            <mxPoint x="730" y="650" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg14" value="14. {success: true, action: OPEN_BARRIER}" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="680" as="sourcePoint"/>
            <mxPoint x="130" y="680" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="lpr-msg15" value="15. GPIO.output(BARRIER_PIN, HIGH)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;strokeColor=#d79b00;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="710" as="sourcePoint"/>
            <mxPoint x="930" y="710" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  
