          <mxGeometry x="930" y="60" width="100" height="750" as="geometry"/>
        </mxCell>
        
        <!-- Messages -->
        <mxCell id="msg1" value="1. POST /api/bookings" style="html=1;verticalAlign=bottom;endArrow=block;entryX=0;entryY=0;rounded=0;" edge="1" parent="1">
