  <diagram id="sequence-booking" name="2. Sequence - Booking Flow">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title2" value="&lt;b&gt;Sequence Diagram - Parking Booking Flow&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="30" as="geometry"/>
        </mxCell>
        <!-- Lifelines -->
        <mxCell id="driver2" value="Driver&#xa;(Mobile App)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff2cc;strokeColor=#d6b656;size=60;" vertex="1" parent="1">
          <mxGeometry x="100" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="api2" value="Backend&#xa;API Server" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=60;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="db2" value="Database&#xa;(PostgreSQL)" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;size=60;" vertex="1" parent="1">
          <mxGeometry x="500" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="ws2" value="WebSocket&#xa;Service" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=60;" vertex="1" parent="1">
          <mxGeometry x="700" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="notif2" value="Notification&#xa;Service" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=1;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#f8cecc;strokeColor=#b85450;size=60;" vertex="1" parent="1">
          <mxGeometry x="900" y="60" width="100" height="700" as="geometry"/>
        </mxCell>
        <!-- Messages -->
        <mxCell id="msg1" value="1. GET /api/parking/map" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="150" y="150" as="sourcePoint"/>
            <mxPoint x="350" y="150" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg2" value="2. Query spots status" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="170" as="sourcePoint"/>
            <mxPoint x="550" y="170" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg3" value="3. Return spots[]" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="190" as="sourcePoint"/>
            <mxPoint x="350" y="190" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg4" value="4. Return parking map data" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="210" as="sourcePoint"/>
            <mxPoint x="150" y="210" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg5" value="5. Select spot (e.g., SP-15)" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="150" y="260" as="sourcePoint"/>
            <mxPoint x="350" y="260" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg6" value="6. Check spot availability" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="280" as="sourcePoint"/>
            <mxPoint x="550" y="280" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg7" value="7. Spot is FREE" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="300" as="sourcePoint"/>
            <mxPoint x="350" y="300" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg8" value="8. Check user no-show count" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="330" as="sourcePoint"/>
            <mxPoint x="550" y="330" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg9" value="9. no_show_count = 2 (OK)" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="350" as="sourcePoint"/>
            <mxPoint x="350" y="350" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg10" value="10. POST /api/bookings" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="150" y="400" as="sourcePoint"/>
            <mxPoint x="350" y="400" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg11" value="11. BEGIN TRANSACTION" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="420" as="sourcePoint"/>
            <mxPoint x="550" y="420" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg12" value="12. INSERT booking" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="440" as="sourcePoint"/>
            <mxPoint x="550" y="440" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg13" value="13. UPDATE spot status = BOOKED" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="460" as="sourcePoint"/>
            <mxPoint x="550" y="460" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg14" value="14. COMMIT" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="480" as="sourcePoint"/>
            <mxPoint x="350" y="480" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg15" value="15. Broadcast spot update" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="510" as="sourcePoint"/>
            <mxPoint x="750" y="510" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg16" value="16. WS: spot_status_changed" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="750" y="530" as="sourcePoint"/>
            <mxPoint x="150" y="530" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg17" value="17. Send booking confirmation" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="560" as="sourcePoint"/>
            <mxPoint x="950" y="560" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg18" value="18. SMS: &quot;Booking confirmed, arrive in 15 min&quot;" style="html=1;verticalAlign=bottom;endArrow=block;rounded=0;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="950" y="580" as="sourcePoint"/>
            <mxPoint x="150" y="580" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="msg19" value="19. Return booking details" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="350" y="620" as="sourcePoint"/>
            <mxPoint x="150" y="620" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <!-- Notes -->
        <mxCell id="note1" value="15-minute arrival window&#xa;starts after booking" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="400" y="600" width="140" height="50" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
